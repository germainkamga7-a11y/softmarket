rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Logos commerces/établissements : lecture publique, écriture propriétaire du commerce
    match /commerces/{commerceId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/commercants/$(commerceId))
             .data.user_id == request.auth.uid;
    }

    // Images produits : lecture publique, écriture propriétaire du commerce
    match /produits/{commerceId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/commercants/$(commerceId))
             .data.user_id == request.auth.uid;
    }

    // Images profil utilisateurs
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
