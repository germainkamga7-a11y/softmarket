rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isNotAnonymous() {
      return isAuth() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function notChanging(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ── Utilisateurs ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        && hasFields(['username', 'created_at']);
      // Autorise la mise à jour de tous les champs sauf phone (si déjà renseigné)
      // et created_at. Exception : si phone est vide dans le doc existant, on
      // peut le renseigner (cas inscription après connexion anonyme).
      allow update: if isOwner(userId)
        && notChanging(['created_at'])
        && (notChanging(['phone']) || resource.data.phone == '');
      allow delete: if isOwner(userId);
    }

    // ── Commerces / Boutiques ─────────────────────────────────────────────────
    match /commercants/{commerceId} {
      allow read: if true;
      allow create: if isNotAnonymous()
        && hasFields(['nom_boutique', 'user_id', 'position', 'type', 'created_at'])
        && request.resource.data.user_id == request.auth.uid
        // verified ne peut être mis qu'à false à la création
        && (!request.resource.data.keys().hasAll(['verified'])
            || request.resource.data.verified == false);
      allow update: if isAuth()
        && resource.data.user_id == request.auth.uid
        // Interdire la modification de verified, user_id et created_at
        && notChanging(['verified', 'user_id', 'created_at']);
      allow delete: if isAuth()
        && resource.data.user_id == request.auth.uid;
    }

    // ── Produits ──────────────────────────────────────────────────────────────
    function isCommerceOwner(commerceId) {
      return isAuth() &&
        get(/databases/$(database)/documents/commercants/$(commerceId))
          .data.user_id == request.auth.uid;
    }

    match /produits/{produitId} {
      allow read: if true;
      allow create: if isNotAnonymous()
        && hasFields(['nom', 'commerce_id', 'created_at'])
        && isCommerceOwner(request.resource.data.commerce_id);
      allow update: if isCommerceOwner(resource.data.commerce_id)
        && notChanging(['commerce_id', 'created_at']);
      allow delete: if isCommerceOwner(resource.data.commerce_id);
    }

    // ── Favoris ───────────────────────────────────────────────────────────────
    match /favorites/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Avis ──────────────────────────────────────────────────────────────────
    match /reviews/{commerceId} {
      // Agrégat (avg_rating, count) : lecture publique, mise à jour via transaction auth
      allow read: if true;
      allow write: if isAuth();

      match /items/{userId} {
        allow read: if true;
        allow create, update: if isNotAnonymous()
          && isOwner(userId)
          && hasFields(['rating', 'created_at'])
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow delete: if isOwner(userId);
      }
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isAuth()
        && resource != null
        && request.auth.uid in resource.data.participants;
      allow create: if isNotAnonymous()
        && request.auth.uid in request.resource.data.participants
        && hasFields(['participants', 'created_at']);
      allow update: if isAuth()
        && resource != null
        && request.auth.uid in resource.data.participants
        && notChanging(['participants', 'created_at'])
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['last_message', 'last_message_at', 'updated_at', 'participant_names']);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuth()
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isNotAnonymous()
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants
          && request.resource.data.sender_id == request.auth.uid
          && hasFields(['text', 'sender_id', 'created_at']);
        allow update, delete: if false;
      }
    }

    // ── Commandes ─────────────────────────────────────────────────────────────

    // Vérifie que le commerce concerné appartient à l'utilisateur connecté
    function isSellerOfOrder() {
      return isAuth() &&
        resource.data.items.size() > 0 &&
        get(/databases/$(database)/documents/commercants/$(resource.data.items[0].commerceId))
          .data.user_id == request.auth.uid;
    }

    // Transitions de statut autorisées pour le vendeur
    function isValidSellerTransition() {
      return (resource.data.statut == 'en_attente'   && request.resource.data.statut == 'confirmee')
          || (resource.data.statut == 'confirmee'    && request.resource.data.statut == 'en_livraison')
          || (resource.data.statut == 'en_livraison' && request.resource.data.statut == 'livree');
    }

    match /commandes/{commandeId} {
      // L'acheteur peut créer et lire ses propres commandes (pas les anonymes)
      allow create: if isNotAnonymous()
        && request.resource.data.userId == request.auth.uid
        && hasFields(['userId', 'items', 'total', 'adresseLivraison', 'telephone', 'statut', 'createdAt']);
      allow read: if isAuth()
        && (resource.data.userId == request.auth.uid || isSellerOfOrder());
      // Acheteur : annuler si en_attente
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && resource.data.statut == 'en_attente'
        && request.resource.data.statut == 'annulee'
        && notChanging(['userId', 'items', 'total', 'createdAt']);
      // Vendeur : faire avancer le statut (confirmee → en_livraison → livree)
      allow update: if isSellerOfOrder()
        && isValidSellerTransition()
        && notChanging(['userId', 'items', 'total', 'adresseLivraison', 'telephone', 'createdAt', 'modePaiement']);
      allow delete: if false;
    }

    // ── Demandes de vérification d'identité ───────────────────────────────────
    match /verification_requests/{userId} {
      // L'utilisateur peut créer/remplacer sa propre demande (pending uniquement)
      allow create: if isOwner(userId)
        && request.resource.data.status == 'pending'
        && hasFields(['uid', 'full_name', 'cni_number', 'cni_front_url',
                      'selfie_url', 'submitted_at']);
      // Renvoi après refus : replace avec status pending
      allow update: if isOwner(userId)
        && request.resource.data.status == 'pending'
        && resource.data.status == 'rejected';
      // L'utilisateur peut lire sa propre demande
      allow read: if isOwner(userId);
      // Approbation/refus réservés à l'admin (Firebase Console ou Cloud Function)
      allow delete: if false;
    }

    // ── Signalements ──────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isNotAnonymous()
        && request.resource.data.reporter_uid == request.auth.uid
        && hasFields(['reporter_uid', 'target_type', 'target_id', 'reason', 'created_at'])
        && request.resource.data.target_type in ['commerce', 'produit', 'utilisateur']
        && request.resource.data.status == 'pending';
      // Lecture et modération réservées à l'admin via Firebase Console
      allow read, update, delete: if false;
    }
  }
}
